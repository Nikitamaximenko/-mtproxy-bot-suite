DATABASE_URL=sqlite:///./app.db

# Public URL of backend (used for webhooks redirect/links)
PUBLIC_BASE_URL=http://localhost:8000

# Subscription price (RUB)
PAYMENT_AMOUNT_RUB=299

# lava.top Public API (required for payments)
# Get keys at: app.lava.top → Integrations → Public API
# Docs: https://developers.lava.top/en
LAVA_TOP_API_BASE_URL=https://gate.lava.top
LAVA_TOP_API_KEY=
LAVA_TOP_OFFER_ID=

# If invoice create fails for a monthly subscription in RUB, set (see Lava Swagger examples):
# LAVA_TOP_PERIODICITY=MONTHLY
# LAVA_TOP_PAYMENT_PROVIDER=SMART_GLOCAL
# LAVA_TOP_PAYMENT_METHOD=CARD

# Webhook auth: create separate key in Lava for webhooks, add to X-Api-Key header
LAVA_TOP_WEBHOOK_API_KEY=

# Legacy fallback when Lava API fails: replace YOUR_ID with your Lava pay link ID
LAVA_PAY_URL_TEMPLATE=https://lava.top/pay/YOUR_ID?order_id={payment_token}

# MTProxy server (single server for MVP)
MT_PROXY_SERVER=176.123.161.97
MT_PROXY_PORT=443
MT_PROXY_SECRET=dd645eba01a59f188b5ba9db2564b44a00

# Admin: Telegram chat ID to receive payment notifications (optional)
ADMIN_NOTIFY_CHAT_ID=

# Telegram Bot API (same token as bot) — отправка уведомлений и sales nudges с бэкенда
BOT_TOKEN=

# Публичный URL фронта с мини-аппом оплаты (для кнопки web_app в рассылках; тот же что у бота FRONTEND_URL)
FRONTEND_URL=https://your-frontend.example

# Путь мини-аппа на фронте (как MINIAPP_PATH у бота), по умолчанию /mini
MINIAPP_PATH=/mini

