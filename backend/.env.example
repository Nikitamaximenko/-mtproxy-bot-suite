DATABASE_URL=sqlite:///./app.db

# Public URL of backend (used for webhooks redirect/links)
PUBLIC_BASE_URL=http://localhost:8000

# Subscription price (RUB)
PAYMENT_AMOUNT_RUB=199

# lava.top Public API (recommended)
# Docs: https://developers.lava.top/en
# API calls auth: X-Api-Key = LAVA_TOP_API_KEY
LAVA_TOP_API_BASE_URL=https://gate.lava.top
LAVA_TOP_API_KEY=
LAVA_TOP_OFFER_ID=

# Webhook auth: lava.top will send this in X-Api-Key header to your webhook endpoint
LAVA_TOP_WEBHOOK_API_KEY=

# Legacy fallback (if API keys not set or API call fails; keeps local dev working)
LAVA_PAY_URL_TEMPLATE=https://lava.top/pay/YOUR_ID?order_id={payment_token}

# MTProxy server (single server for MVP)
MT_PROXY_SERVER=46.8.61.111
MT_PROXY_PORT=443
MT_PROXY_SECRET=eeac423189c49ea4883f6030cdb52e947f79612e7275

