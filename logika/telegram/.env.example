# Subscription providers
LAVA_SECRET_KEY=
PRODAMUS_SECRET=

# Voice ASR provider (Deepgram / Whisper / Yandex SpeechKit)
ASR_PROVIDER=
ASR_API_KEY=

# Logging
LOG_LEVEL=info
