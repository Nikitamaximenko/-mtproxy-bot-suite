# Скопируй в .github/workflows/system-audit.yml и запушь (нужен PAT с scope workflow).
# Секреты репозитория: BACKEND_URL, ADMIN_API_KEY, INTERNAL_API_TOKEN — те же, что в Railway.
name: System audit

on:
  workflow_dispatch:

jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Run system audit
        env:
          BACKEND_URL: ${{ secrets.BACKEND_URL }}
          ADMIN_API_KEY: ${{ secrets.ADMIN_API_KEY }}
          INTERNAL_API_TOKEN: ${{ secrets.INTERNAL_API_TOKEN }}
        run: python3 scripts/system_audit.py
      - name: Upload NDJSON log
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: system-audit-log
          path: .cursor/debug-5f0ad3.log
          if-no-files-found: warn
