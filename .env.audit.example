# Скопируй в .env.audit и заполни — scripts/system_audit.py подхватит автоматически.
# .env.audit в .gitignore — секреты не утекут.

BACKEND_URL=https://mtproxy-bot-suite-production.up.railway.app

# Значения из Railway → сервис бэкенда → Variables
ADMIN_API_KEY=
INTERNAL_API_TOKEN=

# Опционально: для --with-self-test
SELF_TEST_TG_ID=591337712

# ── Альтернатива: GitHub Actions ───────────────────────────────────────────
# Скопируй scripts/gha-system-audit.yml.example → .github/workflows/system-audit.yml
# (push возможен только с PAT, у которого есть scope «workflow»).
# Settings → Secrets → Actions: BACKEND_URL, ADMIN_API_KEY, INTERNAL_API_TOKEN
# Actions → System audit → Run workflow → артефакт system-audit-log
