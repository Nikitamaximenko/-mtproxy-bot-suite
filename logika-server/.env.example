# PostgreSQL (Railway: переменная DATABASE_URL подставляется автоматически)
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# JWT (сгенерируй длинную случайную строку)
JWT_SECRET=change-me-min-32-chars-random-secret

# CORS: свой домен и localhost (через запятую). *.vercel.app покрывается в коде API отдельно.
CORS_ORIGINS=https://your-custom-domain.com,http://localhost:5173

# Публичный URL этого бэкенда (для ссылок на PDF)
PUBLIC_API_URL=https://your-logika-api.up.railway.app

# SMS Aero — https://smsaero.ru/integration/documentation/api/
SMSAERO_EMAIL=your@email.ru
SMSAERO_API_KEY=
# Подпись отправителя из кабинета SMS Aero
SMSAERO_SIGN=SMS Aero
# Локально без SMS: true (код в логах). На Railway в prod = false и обязательны EMAIL+KEY.
SMSAERO_ALLOW_LOG_ONLY=true
# true = API sms/testsend (тестовая отправка по доке SMS Aero). На проде обычно false.
SMSAERO_TEST_MODE=false

# Anthropic — каскад (id моделей см. консоль Anthropic). На Railway обязателен для реального Opus/Sonnet.
ANTHROPIC_API_KEY=
# Локально true = шаблонные ответы без вызова API. На prod не задавай или false.
ANTHROPIC_ALLOW_DEMO_WITHOUT_KEY=true
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MODEL_ROUTER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_QUESTIONS=claude-opus-4-7
ANTHROPIC_MODEL_ANALYSIS=claude-opus-4-7
ANTHROPIC_MODEL_CRITIQUE=claude-opus-4-7
OPUS_EFFORT=high
ENABLE_ROUTER=true
ENABLE_SELF_CRITIQUE=true
