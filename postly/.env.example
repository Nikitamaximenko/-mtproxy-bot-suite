# Для Vercel деплоя нужны:
# DATABASE_URL (Neon pooled), DIRECT_URL (Neon direct — для migrate на сборке),
# AUTH_SECRET, AUTH_URL
# AUTH_URL должен быть полным production URL после деплоя
# (например https://postly.vercel.app)
#
# Neon: в дашборде два URI — «pooled» в DATABASE_URL, «direct» в DIRECT_URL.

DATABASE_URL=""
DIRECT_URL=""
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT=""
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Postly <noreply@postly.local>"
POSTMYPOST_API_TOKEN=""
POSTMYPOST_API_BASE_URL="https://app.postmypost.io/api/v4.1"
TELEGRAM_BOT_TOKEN=""
