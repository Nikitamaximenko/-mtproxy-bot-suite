# Backend API URL. In production (Railway/Vercel) set to your backend, e.g.:
# BACKEND_URL=https://mtproxy-bot-suite-production.up.railway.app
BACKEND_URL=http://localhost:8000

# Default checkout provider for the UI: lava or yookassa.
# Can be temporarily overridden in the browser with ?pay=yookassa or ?pay=lava
NEXT_PUBLIC_DEFAULT_PAYMENT_PROVIDER=lava
