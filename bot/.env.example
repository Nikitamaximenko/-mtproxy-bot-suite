BOT_TOKEN=123456:ABCDEF-your-token
BACKEND_BASE_URL=http://localhost:8000

# Optional: frontend URL for "buy" button (fallback)
FRONTEND_URL=http://localhost:3000

# Optional: support username (without @) for the '🆘 Поддержка' link — если не используете ИИ-поддержку
SUPPORT_USERNAME=your_username

# ИИ-поддержка: ответы в этом же чате. Кнопка «Поддержка» больше не открывает личку (t.me).
# Если OPENROUTER_API_KEY или OPENAI_API_KEY задан — ИИ включается автоматически.
# SUPPORT_AI_ENABLED=false — принудительно без ИИ; true — с ИИ даже без ключа (тогда покажется ошибка настройки).
#
# OpenRouter (по умолчанию): https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# По умолчанию используется openrouter/free — смарт-роутер по живым free-моделям
# (обходит upstream rate-limits; корректно эмитит tool_calls). Fallback — openai/gpt-oss-120b:free.
# Альтернативы, если захочешь прибить гвоздями конкретную модель:
#   openai/gpt-oss-120b:free, nvidia/nemotron-3-super-120b-a12b:free, openrouter/elephant-alpha,
#   meta-llama/llama-3.3-70b-instruct:free (часто 429).
# Полный список: https://openrouter.ai/models?pricing=free
# SUPPORT_AI_MODEL=openrouter/free
# SUPPORT_AI_FALLBACK_MODEL=openai/gpt-oss-120b:free
# SUPPORT_AI_TEMPERATURE=0.35
# SUPPORT_AI_HISTORY_LIMIT=12
# OPENROUTER_HTTP_REFERER=https://your-frontend.example
# OPENROUTER_APP_NAME=Frosty Support
#
# Либо прямой OpenAI: OPENAI_API_KEY=... и OPENAI_BASE_URL=https://api.openai.com/v1
#
# Выдача бесплатного доступа ИИ: по умолчанию ВЫКЛ. Включи только если уверен в модели и нужен самообслуживаемый fallback.
# SUPPORT_AI_ALLOW_GRANT=false
# Должен совпадать с INTERNAL_API_TOKEN в backend — без него /internal/support/activate вернёт 403.
# INTERNAL_API_TOKEN=same_as_backend

# Optional: displayed subscription price (must match your lava.top offer)
PRICE_RUB=299

# Optional: which path of FRONTEND_URL to open as mini-app
MINIAPP_PATH=/mini

